{
  "request": {
    "method": "POST",
    "url": "/api/v1/levels",
    "bodyPatterns": [
      { "matchesJsonPath": "$.levels[?(!@.name)]" }
    ]
  },
  "response": {
    "status": 400,
    "headers": { "Content-Type": "application/json" },
    "bodyFileName": "level-import-missing-name.json"
  },
  "priority": 1
}