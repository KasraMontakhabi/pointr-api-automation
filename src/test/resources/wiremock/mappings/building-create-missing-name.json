{
  "request": {
    "method": "POST",
    "url": "/api/v1/buildings",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$[?(!@.name)]"
      }
    ]
  },
  "response": {
    "status": 400,
    "headers": { "Content-Type": "application/json" },
    "bodyFileName": "building-create-missing-name.json"
  },
  "priority": 1
}