{
  "request": {
    "method": "POST",
    "url": "/api/v1/buildings",
    "bodyPatterns": [
      {
        "equalToJson": {
          "siteId": "site-001",
          "name": "Duplicate Building",
          "description": "This name already exists in this site",
          "floorCount": 3
        },
        "ignoreExtraElements": true,
        "ignoreArrayOrder": true
      }
    ]
  },
  "response": {
    "status": 409,
    "headers": { "Content-Type": "application/json" },
    "bodyFileName": "building-create-duplicate.json"
  },
  "priority": 1
}