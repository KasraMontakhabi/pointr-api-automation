{
  "request": {
    "method": "POST",
    "url": "/api/v1/sites",
    "bodyPatterns": [
      {
        "equalToJson": {
          "name": "Duplicate Site",
          "description": "This name already exists",
          "address": "456 Copy Street, Istanbul, TR"
        },
        "ignoreExtraElements": true,
        "ignoreArrayOrder": true
      }
    ]
  },
  "response": {
    "status": 409,
    "headers": { "Content-Type": "application/json" },
    "bodyFileName": "site-create-duplicate.json"
  },
  "priority": 1
}