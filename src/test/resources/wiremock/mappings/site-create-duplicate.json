{
  "request": {
    "method": "POST",
    "url": "/api/v1/sites",
    "bodyPatterns": [
      { "equalToJson": "{\"name\": \"Duplicate Site\"}", "ignoreExtraElements": true }
    ]
  },
  "response": {
    "status": 409,
    "headers": { "Content-Type": "application/json" },
    "body": "{\"error\": \"A site with this name already exists\"}"
  }
}