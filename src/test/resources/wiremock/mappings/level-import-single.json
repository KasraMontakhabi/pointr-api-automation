{
  "request": {
    "method": "POST",
    "url": "/api/v1/levels",
    "bodyPatterns": [
      { "matchesJsonPath": "$.levels[?(@.size() == 1)]" }
    ]
  },
  "response": {
    "status": 201,
    "headers": { "Content-Type": "application/json" },
    "bodyFileName": "level-imported-single.json"
  }
}