{
  "request": {
    "method": "POST",
    "url": "/api/v1/levels",
    "bodyPatterns": [
      { "matchesJsonPath": "$.levels[?(!@.name)]" }
    ]
  },
  "response": {
    "status": 400,
    "headers": { "Content-Type": "application/json" },
    "body": "{\"error\": \"Field 'name' is required for each level\"}"
  },
  "priority": 1
}