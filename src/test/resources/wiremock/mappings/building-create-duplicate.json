{
  "request": {
    "method": "POST",
    "url": "/api/v1/buildings",
    "bodyPatterns": [
      { "equalToJson": "{\"name\": \"Duplicate Building\"}", "ignoreExtraElements": true }
    ]
  },
  "response": {
    "status": 409,
    "headers": { "Content-Type": "application/json" },
    "body": "{\"error\": \"A building with this name already exists in this site\"}"
  }
}